# URL base del backend HTTP (sin barra final).
# En Vercel → Settings → Environment Variables (Production + Preview).
# El proxy en /api/* reenvía aquí; el panel en HTTPS usa el mismo dominio, no la IP directa.
API_UPSTREAM=

# Clave API para autenticar con el upstream.
# Definir en Vercel: Settings → Environment Variables
API_KEY=

# ElevenLabs Voice Agent ID (opcional)
# De tu cuenta ElevenLabs → Agentes → tu agente → Agent ID
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=